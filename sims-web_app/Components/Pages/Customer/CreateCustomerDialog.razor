@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using sims_web_app.Data.Model
@using MudBlazor
@using sims_web_app.Services
@inject ISnackbar Snackbar
@inject BackendApiHandler BackendApiHandler



@*// VULNERABILITY: [Missing input validation]
// DESCRIPTION: [Missing input validation allows untrusted data to enter the system unchecked. Attackers can send malicious data directly to the backend.]
// MITIGATION: [All user input must be validated and sanitized on the server side before it is processed or stored. 
Enforce strict rules for each field, such as expected format, length limits, and allowed characters. The backend must validate the same fields too.]
//Example: [MaxLength="100" (reduces risk from too long input),
Validation="@(new Func<string, string>(ValidatePhoneNumber))]*@
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_customer.CompanyName" Label="Firma" Required="true" />
        <MudTextField @bind-Value="_customer.Email" Label="E-Mail" Required="true" />
        <MudTextField @bind-Value="_customer.PhoneNumber" Label="Telefon" />
        <MudTextField @bind-Value="_customer.City" Label="Stadt" />
        <MudTextField @bind-Value="_customer.Country" Label="Land" />
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private Customer _customer = new();

    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    private void Cancel() => MudDialog.Cancel();

    private async void Save()
    {
        bool isCreated = await BackendApiHandler.CreateCustomer(_customer);
        MudDialog.Close(DialogResult.Ok(_customer));

        if (isCreated)
        {
            Snackbar.Add($"Customer {_customer.CompanyName} created successfully!", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Error by creating the customer!", Severity.Error);
        }
    }
}